        <div class="card-body p-3">
          <h6 class="fw-bold mb-1 text-truncate">{{ menu.name }}</h6>
          <p class="small text-muted mb-2 text-truncate">{{ menu.restaurantName }}</p>
          <div class="d-flex justify-content-between align-items-center mt-2">
            <span class="fw-bold fs-6" style="color: #28A745;">{{ menu.price }} F</span>
            <button class="btn btn-sm text-white rounded-pill px-3 py-1 shadow-sm bg-dash-red border-0 fw-bold" style="font-size: 0.75rem;">
              Ajouter +
            </button>
          </div>
        </div>
      </div>
    </div>
    @endeach
  </div>

</div>

<style>
  .fw-800 { font-weight: 800; }
  .menu-card { transition: transform 0.2s ease; cursor: pointer; }
