@section('body')
<div class="container py-4">
  
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-800 tracking-tight mb-0">Menus disponibles</h2>
    <div class="text-muted small d-none d-md-block">Yaoundé, Cameroun</div>
  </div>

  <div class="row g-2 mb-4">
    <div class="col-12">
      <div class="input-group shadow-sm rounded-pill overflow-hidden bg-white border px-2 py-1">
        <span class="input-group-text bg-white border-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-muted" viewBox="0 0 16 16">
            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
